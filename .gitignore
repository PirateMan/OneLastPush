################################################################################
# Unreal Engine Recommended .gitignore
# Safe for ALL UE4/UE5 projects (Blueprint or C++)
################################################################################

# ------------------------------------------------------------------------------
# Editor & User Settings
# ------------------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.sln
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# ------------------------------------------------------------------------------
# Operating System Crap
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Engine-Generated Folders (NEVER track these)
# ------------------------------------------------------------------------------
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# Allow only PakBlacklist inside Build/
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# ------------------------------------------------------------------------------
# Engine-Generated Plugin Folders
# ------------------------------------------------------------------------------
Plugins/*/Binaries/
Plugins/*/Intermediate/

# ------------------------------------------------------------------------------
# Project File Types That Can Be Regenerated
# ------------------------------------------------------------------------------
*.xcodeproj
*.xcworkspace
*.xcuserstate
*.pdb
*.obj
*.o
*.lo
*.slo
*.gch
*.pch
*.mod
*.tmp
*.bak

# ------------------------------------------------------------------------------
# Precompiled Assets (never track raw source art)
# ------------------------------------------------------------------------------
SourceArt/**/*.png
SourceArt/**/*.tga

# ------------------------------------------------------------------------------
# Map Build Data
# ------------------------------------------------------------------------------
*_BuiltData.uasset

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log

# ------------------------------------------------------------------------------
# Crash Reports
# ------------------------------------------------------------------------------
CrashReportClient
Saved/Logs/
Saved/Crashes/

# ------------------------------------------------------------------------------
# Automation / Test Artifacts
# ------------------------------------------------------------------------------
Saved/Automation/
Saved/Backups/
Saved/StagedBuilds/
Saved/CookTmp/

# ------------------------------------------------------------------------------
# Project-specific Saved settings (regenerated by UE)
# ------------------------------------------------------------------------------
Saved/Config/
Saved/Cooked/
Saved/Collections/
Saved/EditorCooker/
Saved/Logs/
Saved/Profiling/
Saved/Temp/

# ------------------------------------------------------------------------------
# Derived Data Cache (Editor temp)
# ------------------------------------------------------------------------------
DerivedDataCache/

# ------------------------------------------------------------------------------
# Ignore Local Build Artifacts
# ------------------------------------------------------------------------------
*.opendb
*.tlog
*.cache
*.db
*.mdb
*.opendb
*.idb
*.ilk
*.map
*.res
*.iobj
*.ipdb

# ------------------------------------------------------------------------------
# Mobile Packaging Junk
# ------------------------------------------------------------------------------
*.apk
*.ipa

# ------------------------------------------------------------------------------
# Administrative / Metadata Files
# ------------------------------------------------------------------------------
*.aps
*.ncb

# ------------------------------------------------------------------------------
# Unreal Simulation / Virtual Production cache
# ------------------------------------------------------------------------------
Saved/LiveEdit/
Saved/TakeRecorder/
